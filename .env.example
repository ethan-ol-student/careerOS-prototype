# ─────────────────────────────────────────────────────────────
# Career OS — environment variables (copy to .env.local for dev)
# ─────────────────────────────────────────────────────────────

# Database (Neon Postgres)
DATABASE_URL=
# Optional direct (non-pooled) connection for migrations
DIRECT_URL=

# Seed guard — when not "false", `npm run db:seed` populates the demo
# catalog (candidates, companies, jobs, salary benchmarks), all labelled
# isDemo. Set SEED_DEMO=false in production to skip demo data. Remove
# already-seeded demo rows via POST /api/dev/reset { "scope": "demo" }.
SEED_DEMO=true

# Auth — JWT signing secret. REQUIRED in production (the app refuses to
# sign/verify sessions without it). Use a long, random value.
AUTH_SECRET=

# Optional API base override (leave blank for same-origin requests)
NEXT_PUBLIC_API_BASE_URL=

# ── Google SSO (Feature 7) — OPTIONAL, fully inert when unset ────
# Server credentials: routes 404 without BOTH set. Redirect URI defaults
# to <origin>/api/auth/google/callback; override for tunnels/proxies.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Shows the "Continue with Google" button (client flag — the risk
# backup: unset it to hide SSO instantly if redirect issues appear).
NEXT_PUBLIC_ENABLE_GOOGLE_SSO=false

# Simulated candidate chat replies (employer chat). Demo only — OFF by
# default so production never shows a fake reply as a real one.
NEXT_PUBLIC_ENABLE_DEMO_CHAT=false

# ─────────────────────────────────────────────────────────────
# Developer / Test Mode — LOCAL / DEV ONLY.
# When "true": unlocks /dev/test-mode and seeds the admin123 test
# account. NEVER set this in a production environment.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TEST_MODE=false
