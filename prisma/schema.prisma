// Career OS — Postgres (Neon) schema.
//
// Design notes:
// - One `User` row per real account (candidate OR employer). Auth is
//   first-party: bcrypt password hash on this row + a signed-JWT session
//   cookie (see `src/lib/auth/*`). Every owned row FKs back to `User`.
// - `Candidate` is the marketplace catalog — currently seeded from
//   `src/lib/candidates/data.ts`. Catalog candidates are distinct from
//   "real" candidate users (`User.role = CANDIDATE` + `CandidateProfile`)
//   so the prototype demo never breaks when real signups exist.
// - Enum-like strings (severity, kind, growth signal, etc.) are kept as
//   `String` to avoid migrating Postgres enums every time a TS literal
//   changes. The TS API layer is the source of truth for legal values.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth-adjacent ──────────────────────────────────────────────

enum UserRole {
  CANDIDATE
  EMPLOYER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String?
  name         String?
  role         UserRole
  isJudgeAccount Boolean @default(false)
  // Session revocation: bumped on logout (invalidates every issued token
  // for this user). The signed JWT carries the version at sign time;
  // getAuthUser rejects a token whose version is stale. See auth/session.ts.
  sessionVersion Int    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidateProfile CandidateProfile?
  employerProfile  EmployerProfile?
  candidatesAI     CandidatesAI?
  employersAI      EmployersAI?
  oauthAccounts    OAuthAccount[]
  subscription     Subscription?

  // Optional projection of this user into the marketplace catalog
  // (only for real candidates who opt into discovery). See `Candidate`.
  marketplaceCandidate Candidate?
}

// ── Subscription (Feature 15 — freemium) ────────────────────────
// One row per user; `plan` legal values owned by src/lib/billing/plans.ts.
// MOCK billing: upgrading flips `plan` locally (POST /api/me/subscription);
// real payment processing is explicitly post-deploy scope. Judges bypass
// entitlements entirely via User.isJudgeAccount — see entitlements.ts.

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan String @default("free") // "free" | "pro"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── OAuth / SSO (Google) ────────────────────────────────────────
// Links a third-party identity to a `User`. The OAuth callback finds the
// account here (or creates User+OAuthAccount) and mints the SAME `jose`
// session cookie used by password auth — see docs/sso-google-design.md.
// Model + migration only; NO UI yet (planned Week 4). `passwordHash` on
// `User` is already optional, so SSO-only accounts need no password.

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "google"
  providerAccountId String // provider's stable subject id (Google `sub`)
  email             String? // email asserted by the provider
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ── Candidate side ─────────────────────────────────────────────

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Intent fields
  stage     String   @default("")
  goals     String[] @default([])
  name      String   @default("")
  field     String   @default("")
  targetJob String   @default("")

  // Portfolio CV fields
  headline String   @default("")
  summary  String   @default("")
  skills   String[] @default([])
  bio      String   @default("")

  // Contact (onboarding v2) — optional, owner-visible
  phone    String @default("")
  location String @default("")
  nickname String @default("") // onboarding v3 — dashboard greeting; falls back to name

  // Candidate-controlled discovery opt-in. When true, the candidate is
  // projected into the marketplace `Candidate` catalog (visible to
  // employers). Off by default — discovery is the candidate's choice.
  discoverable Boolean @default(false)

  totalAdditions Int       @default(0)
  lastUpdated    DateTime?

  // Age-adaptive UI override (never locked to age): "" = use the phase
  // default; legal values owned by src/lib/dashboard/uiDensity.ts.
  uiDensity String @default("") // "" | "calm" | "vibrant"

  // Timeline / Living Portfolio (Phase 2) — display metadata ONLY. Entries
  // themselves derive from experiences/certificates/projects/skillClaims;
  // this stores the customisable heading prefix and the per-entry flags:
  // { [entryKey]: { major?: boolean, ai?: boolean, evidence?: string } }.
  timelinePrefix String @default("My Journey")
  timelineMeta   Json?

  certificates  Certificate[]
  awards        Award[]
  projects      Project[]
  experiences   Experience[]
  chapters       ChapterEvent[]
  journalEntries TimelineJournalEntry[]
  notifications  CandidateNotification[]
  applications   Application[]
  midCareer      MidCareerProfile?
  resumeVersions ResumeVersion[]
  personality    PersonalityResult?
  xpEntries      XpLedger[]
  streak         Streak?
  badges         Badge[]
  skillClaims    SkillClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Skills Truth (flagship) ────────────────────────────────────────
// Every skill carries a trust tier: 1 self-claimed, 2 evidence-backed,
// 3 endorsed. The tier is DERIVED server-side from evidence/endorsement
// (never client-set); weights live in src/lib/intelligence/skillTruthEngine.ts.
model SkillClaim {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name         String
  level        Int    @default(3) // claimed proficiency 1–5
  tier         Int    @default(1) // 1 | 2 | 3 — derived from the fields below
  evidence     String @default("") // link or concrete situation proving it (tier 2)
  endorsedBy   String @default("") // endorser name (tier 3)
  endorserNote String @default("") // endorser relationship/context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, name])
}

model Certificate {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  issuer    String
  year      String

  @@index([profileId])
}

model Award {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  year        String
  description String?

  @@index([profileId])
}

model Project {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String
  link        String?

  @@index([profileId])
}

model Experience {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role      String // role title — or the problem/project title when kind="project"
  company   String
  period    String
  detail    String?

  // Structured merge (mentor spec): Experience/Project/Problems-solved are
  // ONE section. Legacy Project rows stay and display merged; new project
  // entries are Experience rows with kind="project". TS owns legal values.
  kind         String   @default("role") // "role" | "project"
  contribution String   @default("") // "" | "lead" | "assistant" | "participant"
  approach     String   @default("") // how did you solve it?
  impact       String   @default("") // impact / outcome
  skillsUsed   String[] @default([]) // auto-added to the Skill Radar as tier-1 claims
  link         String?

  @@index([profileId])
}

model ChapterEvent {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  priority  String // "high" | "medium" | "low" — enforced in API layer
  date      String
  time      String
  subtasks  Json // [{ id, label, done }]
  // "Does this move me toward my ideal self?" reflection: null = unrated,
  // true = meaningful, false = not. Powers the meaningful-time analytics.
  meaningful Boolean?
  createdAt DateTime         @default(now())

  @@index([profileId])
}

// Timeline Journal (Life Chapter Designer sub-page) — the narrative source
// for narrativeThemeEngine. Free-text reflections the timetable can't hold;
// mood/skillsTouched/pivot are the structured signal the engine reads.
model TimelineJournalEntry {
  id            String           @id @default(cuid())
  profileId     String
  profile       CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date          String // YYYY-MM-DD (matches ChapterEvent convention)
  title         String
  reflection    String           @default("")
  mood          String           @default("") // "" | energized | steady | drained | proud | uncertain
  skillsTouched String[]         @default([])
  pivot         Boolean          @default(false) // marks a turning point
  createdAt     DateTime         @default(now())

  @@index([profileId, date])
}

model CandidateNotification {
  id          String           @id @default(cuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind        String // "skill" | "system" | "job-match"
  severity    String // "info" | "important"
  title       String
  body        String
  actionLabel String?
  payload     Json?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([profileId, createdAt])
}

// ── Employer side ──────────────────────────────────────────────

model EmployerProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName       String?
  talentType             String   @default("")
  role                   String   @default("")
  priorities             String[] @default([])
  locationPreference     String?
  hasCompletedOnboarding Boolean  @default(false)

  savedCandidates   EmployerSavedCandidate[]
  invitedCandidates EmployerInvitedCandidate[]
  notifications     EmployerNotification[]
  conversations     ChatConversation[]
  jobs              Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Many-to-many: which catalog candidates an employer has saved.
model EmployerSavedCandidate {
  employerId  String
  candidateId String
  savedAt     DateTime @default(now())

  employer  EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidate Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@id([employerId, candidateId])
  @@index([candidateId])
}

model EmployerInvitedCandidate {
  employerId  String
  candidateId String
  invitedAt   DateTime @default(now())

  employer  EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidate Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@id([employerId, candidateId])
  @@index([candidateId])
}

model EmployerNotification {
  id          String          @id @default(cuid())
  employerId  String
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  kind        String // "invite-accepted" | "invite-pending" | "system"
  title       String
  body        String
  candidateId String?
  read        Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([employerId, createdAt])
}

// ── Messaging ──────────────────────────────────────────────────

model ChatConversation {
  id          String          @id @default(cuid())
  employerId  String
  candidateId String
  employer    EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidate   Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employerId, candidateId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String // "employer" | "candidate"
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

// ── Advanced Candidate onboarding answers (AI-personalization input) ──
// Separate from `CandidateProfile` so the "Living Portfolio" stays
// the user-facing CV and this row holds the longer guided answers
// that drive dashboard personalization + future AI recommendations.

model CandidatesAI {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 1 — Stage
  careerStage        String @default("") // student / young-adult / early / mid / senior / executive
  careerStageMeaning String @default("")

  // Step 2 — Discovery
  targetRoles          String[] @default([])
  interestedIndustries String[] @default([])
  opportunityTypes     String[] @default([])
  locationPreference   String?
  availability         String?

  // Step 3 — Growth
  currentSkills      String[] @default([])
  skillLevels        Json? // { [skill]: "beginner" | "intermediate" | "expert" }
  projects           String[] @default([])
  skillsToImprove    String[] @default([])
  weeklyLearningTime String?

  // Step 4 — Progression
  desiredNextMove  String  @default("")
  longTermGoal     String?
  timeline         String?
  careerConfidence String?
  mainBlocker      String?

  // Step 5 — Feedback
  applicationsSent       String?
  interviewExperience    String?
  rejectionsOrChallenges String?
  resumeConfidence       String?
  portfolioConfidence    String?
  interviewConfidence    String?

  dashboardPersonalizationSummary String?
  onboardingCompleted             Boolean @default(false)

  // Onboarding v2 — preferences (additive; TS layer owns legal values)
  desiredLocations    String[] @default([])
  openToRelocate      Boolean  @default(false)
  workArrangement     String[] @default([]) // "remote" | "hybrid" | "onsite"
  topValues           String[] @default([]) // ordered, max 3
  scheduleFlexibility String[] @default([])
  travelWillingness   String   @default("") // "" | "none" | "occasional" | "frequent"
  workEnvironment     String   @default("") // "" | "structured" | "fast_moving" | "independent" | "collaborative"
  maxCommuteMinutes   Int?
  minSalaryAmount     Int?
  minSalaryPeriod     String   @default("") // "" | "hourly" | "monthly" | "yearly"
  links               String[] @default([]) // LinkedIn / GitHub / portfolio URLs
  languages           String[] @default([])
  fieldOfStudy        String   @default("") // student stage only
  expectedGraduation  String   @default("")

  // Onboarding v3 — focus (recommendation input) + optional self-ID.
  // PRIVATE by construction: these are NEVER copied into the marketplace
  // projection (src/lib/candidates/projection.ts whitelists fields) and are
  // NEVER an input to any match/score engine. Self-ID is collected only
  // after the review screen and only to understand our community.
  // ponytail: guardrail is "don't add these to projection.ts or any engine",
  // enforced by convention + the projection whitelist, not a type barrier.
  focus         String   @default("") // "" | "improve" | "discovering"
  familyStatus  String   @default("") // "" | "single" | "married" | ...
  gender        String   @default("") // free-ish; "" | "male" | "female" | "other" | ...
  religion      String[] @default([]) // optional, self-ID
  race          String[] @default([]) // optional, self-ID
  age           Int?     // optional, self-ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Advanced Employer onboarding answers (AI-matching input) ──
// Mirrors `CandidatesAI` on the candidate side. Holds the hiring
// intent / company context / candidate-signal data captured in
// the 5-step employer onboarding flow. Drives the marketplace
// personalization card and any future AI-matching layer.

model EmployersAI {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 1 — Company Context
  companyType String   @default("") // Startup / SME / Corporate / …
  industries  String[] @default([])
  teamFocus   String[] @default([])

  // Step 2 — Hiring Goal
  hiringReasons  String[] @default([])
  hiringTimeline String   @default("")

  // Step 3 — Role Direction
  targetRoles          String[] @default([])
  futureRoleDirections String[] @default([])

  // Step 4 — Candidate Signals
  candidateGreenFlags String[] @default([])
  requiredSkills      String[] @default([])
  trainableSkills     String[] @default([])

  // Step 5 — Matching Preferences
  strongFitTypes  String[] @default([])
  workArrangement String   @default("") // On-site / Hybrid / Remote / Flexible
  hiringLocation  String   @default("")

  // Generated narrative summaries surfaced on the dashboard.
  hiringIntentSummary      String?
  futurePathSummary        String?
  bestCandidateTypeSummary String?

  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Marketplace catalog ────────────────────────────────────────
// Static-ish pool of demo candidates. Real candidate signups live in
// CandidateProfile; the marketplace doesn't surface them yet.

model Candidate {
  id                String   @id // seeded ids ("c-amelia-tan") OR "real-<userId>" for projected real candidates
  name              String
  careerDirection   String
  targetRole        String
  industry          String
  category          String
  matchScore        Int
  readinessScore    Int
  growthSignal      String // "Accelerating" | "Steady" | "Emerging" | "Compounding"
  topSkills         String[]
  portfolioProjects String[]
  whyRecommended    String
  location          String
  availability      String
  headline          String
  stage             String

  // ── Real-candidate bridge ────────────────────────────────────
  // `source` distinguishes seeded demo rows from real users projected
  // into the catalog. `userId` links a projected row back to the real
  // `User` so the candidate inbox can resolve employer conversations.
  // `visible` is the live discovery flag (mirrors CandidateProfile.discoverable).
  source  String  @default("seed") // "seed" | "real"
  isDemo  Boolean @default(false) // seedable demo row (vs real/projected)
  // Working-style archetype tag (descriptive context only — NEVER a
  // filter or score input; see personalityEngine.ts + Bias Check copy).
  archetype String @default("")
  userId  String? @unique
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  visible Boolean @default(true)

  savedByEmployers   EmployerSavedCandidate[]
  invitedByEmployers EmployerInvitedCandidate[]
  conversations      ChatConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([matchScore])
  @@index([visible])
  @@index([source])
  @@index([isDemo])
}

// ── Jobs catalogue ──────────────────────────────────────────────
// Seeded from `src/lib/jobs/data.ts` (`TARGET_JOBS`). `Job.id` is the
// natural slug (e.g. "robotics-engineer") so seed upserts stay stable.
// `source` mirrors the Candidate convention ("seed" | "real").

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  sourceUrl String? // citation / company site
  isDemo    Boolean  @default(false)
  // Fit signals for the mid-career "better-fit" comparison
  // (local vs MNC vs smaller-company-more-leadership). String enums
  // per project convention — TS layer owns legal values.
  size     String @default("") // "startup" | "midsize" | "enterprise"
  type     String @default("") // "local" | "mnc" | "startup" | "public-sector"
  location String @default("")

  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDemo])
}

model Job {
  id             String   @id @default(cuid()) // seed rows keep natural slugs
  title          String
  location       String
  duration       String
  field          String
  requiredSkills String[]
  baseMatch      Int
  isDemo         Boolean  @default(false)
  source         String   @default("seed") // "seed" | "real"
  sourceUrl      String? // citation / original job posting

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // ── Employer-posted jobs (additive; seeded catalogue rows keep the
  // defaults: no owner, "active", never expire). Status values owned by
  // src/lib/services/jobs.service.ts: "active" | "expired" | "fulfilled".
  // Soft-delete by design — status flips, rows are never hard-deleted.
  employerId    String?
  employer      EmployerProfile? @relation(fields: [employerId], references: [id], onDelete: Cascade)
  status        String           @default("active")
  expiresAt     DateTime? // null = catalogue job, never expires
  description   String           @default("")
  requirements  String[]         @default([])
  skillWeights  Json? // { [skill]: 1–10 } — skill-matrix vertex values
  budgetMin     Int?
  budgetMax     Int?
  startDate     DateTime?
  timelineWeeks Int?
  teamSize      Int?

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([field])
  @@index([isDemo])
  @@index([employerId])
  @@index([status])
}

// ── Applications data spine ─────────────────────────────────────
// One Application per (candidate, job) — see @@unique (the conflict
// risk: re-applying). Lifecycle is an append-only ApplicationEvent log.
// Status values are owned by the TS layer (applications.service.ts),
// stored as plain String per project convention.

model Application {
  id                 String           @id @default(cuid())
  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  jobId              String
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status    String   @default("submitted") // submitted|reviewing|interview|offer|rejected|withdrawn|expired
  expiresAt DateTime // auto-expire deadline; expire-on-read flips stale rows

  events ApplicationEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateProfileId, jobId])
  @@index([jobId])
  @@index([status])
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type       String // submitted|status_changed|expired
  fromStatus String?
  toStatus   String?

  createdAt DateTime @default(now())

  @@index([applicationId])
}

// ── Fair Pay Calculator ─────────────────────────────────────────
// Curated, cited salary ranges — clearly demo data (see `isDemo` +
// `sourceUrl`). Seeded from `prisma/data/salary_benchmarks.csv`.
// Unique natural key (role+industry+companySize+location) keeps the
// seed idempotent. Percentiles are integers in the row's `currency`.

model SalaryBenchmark {
  id          String   @id @default(cuid())
  role        String
  industry    String
  companySize String // "startup" | "midsize" | "enterprise"
  location    String
  currency    String   @default("USD")
  p25         Int
  p50         Int
  p75         Int
  p90         Int
  sourceUrl   String? // citation for the range
  isDemo      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, industry, companySize, location])
  @@index([role])
  @@index([isDemo])
}

// ── Mid-career profile ──────────────────────────────────────────
// Optional 1:1 extension of CandidateProfile for the mid-career phase.
// `salaryPrivate` is the candidate's own current salary — PRIVATE, never
// projected into the marketplace mirror; used only for the Fair Pay
// comparison against SalaryBenchmark.

model MidCareerProfile {
  id                 String           @id @default(cuid())
  candidateProfileId String           @unique
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  problemsSolved String[] @default([]) // notable problems/impact
  careerPattern  String   @default("") // "specialist" | "generalist" | "pivot" | "zigzag"
  salaryPrivate  Int? // optional, private — never public
  salaryCurrency String   @default("USD")
  lifeFactors    String[] @default([]) // e.g. "relocation-limited", "caregiver", "remote-only"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Personality (Feature 2) ─────────────────────────────────────
// One working-style archetype per candidate, computed DETERMINISTICALLY
// from quiz answers by `personalityEngine.ts`. Descriptive context only —
// never a match-score input, never a filter (bias risk backup).

model PersonalityResult {
  id                 String           @id @default(cuid())
  candidateProfileId String           @unique
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  archetype String // ARCHETYPES id in scoringConfig.ts
  scores    Json // per-archetype points breakdown (the "why")
  answers   Json // raw answers, so a retake is reproducible

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Gamification (Feature 4) ────────────────────────────────────
// XP rewards REAL actions only; streaks are forgivable; cadence is
// age-tuned per phase (daily for younger phases, a quiet monthly
// Career Check-Up for mid-career+). See gamification.service.ts.

model XpLedger {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime         @default(now())

  @@index([profileId])
}

model Streak {
  id          String           @id @default(cuid())
  profileId   String           @unique
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  current     Int              @default(0)
  best        Int              @default(0)
  cadence     String           @default("daily") // "daily" | "monthly"
  lastCheckIn DateTime?
  updatedAt   DateTime         @updatedAt
}

model Badge {
  id        String           @id @default(cuid())
  profileId String
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  key       String // "first-checkin" | "streak-3" | "streak-7" | "streak-30" | ...
  earnedAt  DateTime         @default(now())

  @@unique([profileId, key])
}

// ── Leaderboard (Feature 9) ─────────────────────────────────────
// Curated, cited university employability scores — demo data, seeded
// from prisma/data/universities.csv. Never derived from real users.

model University {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  score     Int // 0–100 curated employability score
  sourceUrl String?
  isDemo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Resume versions (Living Portfolio) ──────────────────────────
// Named snapshots of the candidate's resume at save time. `data` is the
// full JSON snapshot the PDF template renders from, so an old version
// stays reproducible even after the live profile changes.

model ResumeVersion {
  id                 String           @id @default(cuid())
  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  label   String
  summary String @default("")
  data    Json

  createdAt DateTime @default(now())

  @@index([candidateProfileId])
}

// ── Market corpus (Career Intelligence, slice 2) ────────────────────
// Ingested aggregate market signal — NOT applyable jobs (the curated `Job`
// feed stays clean). `MarketPosting` = raw JobStreet rows (real Malaysian
// demand + salary); `MarketFieldDemand` + `SkillDemand` are precomputed
// aggregates the intelligence engines read. Populated by prisma/ingest/*
// (never seeded in prod). Field vocabulary matches `Job.field`.

model MarketPosting {
  id              String  @id @default(cuid())
  rawTitle        String
  normalizedTitle String
  field           String  @default("") // mapped from JobStreet classification domain
  classification  String  @default("")
  salaryMinYr     Int? // annualized (RM); null when the posting had no salary
  salaryMaxYr     Int?
  location        String  @default("")
  industry        String  @default("")
  source          String  @default("jobstreet")
  socCode         String? // fuzzy-matched O*NET occupation (null when no match)

  createdAt DateTime @default(now())

  @@index([field])
  @@index([normalizedTitle])
  @@index([socCode])
}

// ── O*NET occupations (Career Intelligence, slice 3) ────────────────
// Standardized occupations + their distinctive work styles, for the
// candidate-facing Job-Style Compass. NEVER an employer match input (the
// archetype/style is descriptive only — see jobStyleFitEngine + Bias Check).

model Occupation {
  socCode     String @id // O*NET-SOC code, e.g. "15-1252.00"
  title       String
  description String @default("")

  workStyles OccupationWorkStyle[]
  aliases    OccupationTitleAlias[]
}

model OccupationWorkStyle {
  id          String     @id @default(cuid())
  socCode     String
  occupation  Occupation @relation(fields: [socCode], references: [socCode], onDelete: Cascade)
  elementName String // "Achievement Orientation","Innovation",…
  score       Int // 0–100, per-occupation min–max normalized WI weight

  @@unique([socCode, elementName])
  @@index([socCode])
}

model OccupationTitleAlias {
  id         String     @id @default(cuid())
  socCode    String
  occupation Occupation @relation(fields: [socCode], references: [socCode], onDelete: Cascade)
  normalized String // lowercased, de-parenthesized title
  source     String // "reported" | "occupation"

  @@index([normalized])
  @@index([socCode])
}

// Per-field work-style profile — aggregated from matched postings'
// occupations. The Job-Style Compass compares the candidate's archetype
// against this "typical role in your field" profile.
model FieldWorkStyle {
  id          String @id @default(cuid())
  field       String
  elementName String
  score       Int // 0–100 average across the field's matched occupations
  occupations Int    @default(0) // how many occupations backed this average

  @@unique([field, elementName])
  @@index([field])
}

model MarketFieldDemand {
  field          String   @id // "" reserved for a cross-field row
  postingCount   Int      @default(0)
  salaryMinYr    Int?
  salaryMaxYr    Int?
  salaryMedianYr Int?
  currency       String   @default("RM")
  updatedAt      DateTime @updatedAt
}

model SkillDemand {
  id           String   @id @default(cuid())
  skill        String // app-canonical (lower-case)
  field        String   @default("") // "" = global aggregate across fields
  postingCount Int      @default(0) // market postings behind this skill's demand
  demandScore  Int      @default(0) // 0–100 normalized within its scope
  updatedAt    DateTime @updatedAt

  @@unique([skill, field])
  @@index([field])
}
